{
  "name": "firefox-open-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "A privacy-conscious, open-source Firefox assistant for user-approved page context.",
  "license": "MPL-2.0",
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.22.0 <23"
  },
  "scripts": {
    "build": "pnpm build:packages && pnpm build:extension && pnpm build:relay",
    "build:packages": "tsc -b packages/protocol packages/extraction packages/editor packages/prompt-security packages/agent-policy packages/test-fixtures --force",
    "build:extension": "pnpm --filter @open-assistant/extension build",
    "build:extension:production": "pnpm --filter @open-assistant/extension build:production",
    "build:relay": "pnpm --filter @open-assistant/relay build && pnpm --filter @open-assistant/mock-relay build && pnpm --filter @open-assistant/fixture-server build",
    "build:native": "node scripts/build-native.mjs",
    "dev": "pnpm --parallel --filter @open-assistant/extension --filter @open-assistant/relay dev",
    "dev:extension": "pnpm --filter @open-assistant/extension dev",
    "dev:relay": "pnpm --filter @open-assistant/relay dev",
    "lint": "eslint . && pnpm lint:markdown",
    "lint:markdown": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\"",
    "lint:webext": "pnpm build:extension:production && node scripts/webext-lint.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false --force",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "node scripts/e2e.mjs",
    "test:security": "vitest run tests/security",
    "smoke": "node scripts/smoke.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "package:source": "node scripts/package-source.mjs",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:verify": "node scripts/release-verify.mjs",
    "check:data-inventory": "node scripts/check-data-inventory.mjs",
    "check:versions": "node scripts/check-versions.mjs",
    "generate:sbom": "node scripts/sbom.mjs",
    "checksums": "node scripts/checksums.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/firefox-webext-browser": "143.0.0",
    "@types/jsdom": "28.0.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "markdownlint-cli2": "0.23.1",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "web-ext": "10.5.0"
  }
}
